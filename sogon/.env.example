# =============================================================================
# Sogon - 환경 변수 예시
# 이 파일을 복사해서 .env.local 로 만든 뒤 실제 값을 채워주세요.
# cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/<your-project>
# -----------------------------------------------------------------------------

# Supabase 프로젝트 URL (Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"

# Supabase 공개 키 — 브라우저에서도 사용됨 (Project Settings > API > anon/public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_<your-anon-key>"

# Supabase 시크릿 키 — 서버에서만 사용됨, 절대 공개 금지 (Project Settings > API > service_role)
SUPABASE_SECRET_DEFAULT_KEY="sb_secret_<your-service-role-key>"

# Supabase DB 비밀번호 — Supabase CLI 마이그레이션 실행 시 필요 (Project Settings > Database > Password)
SUPABASE_PASSWORD="<your-database-password>"

# -----------------------------------------------------------------------------
# Google OAuth (선택) — Google 로그인을 사용하는 경우에만 필요
# Google Cloud Console > APIs & Services > Credentials 에서 발급
# -----------------------------------------------------------------------------
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID="<your-google-client-id>.apps.googleusercontent.com"
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET="GOCSPX-<your-google-client-secret>"

# -----------------------------------------------------------------------------
# Google Gemini API — AI 리액션 생성에 사용
# https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY="<your-gemini-api-key>"
